---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import { DOCS_NAV } from '../../lib/docsNav';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  return DOCS_NAV.filter((item) => entries.some((e) => e.id === item.slug)).map((item) => {
    const entry = entries.find((e) => e.id === item.slug)!;
    return {
      params: { slug: item.slug },
      props: { nav: item, entry },
    };
  });
}

const { nav, entry } = Astro.props;
const { Content } = await render(entry);

const canonicalPath = withBase(`docs/${nav.slug}`);
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: nav.title,
    description: nav.description,
    author: { '@type': 'Organization', name: 'ntui' },
    isPartOf: { '@type': 'WebSite', name: 'ntui', url: new URL(withBase('/'), Astro.site).toString() },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ntui', item: new URL(withBase('/'), Astro.site).toString() },
      { '@type': 'ListItem', position: 2, name: 'Docs', item: new URL(withBase('docs/getting-started'), Astro.site).toString() },
      { '@type': 'ListItem', position: 3, name: nav.title, item: new URL(canonicalPath, Astro.site).toString() },
    ],
  },
];
---

<DocsLayout
  title={nav.title}
  description={nav.description}
  activeSlug={nav.slug}
  type="article"
  jsonLd={jsonLd}
>
  <article
    class="prose prose-invert prose-stone max-w-none
      prose-headings:font-semibold prose-a:text-orange-300 prose-a:no-underline hover:prose-a:underline
      prose-code:before:content-none prose-code:after:content-none
      prose-code:rounded prose-code:bg-stone-900 prose-code:px-1.5 prose-code:py-0.5 prose-code:text-orange-200
      prose-pre:border prose-pre:border-stone-800 prose-pre:bg-stone-900"
  >
    <Content />
  </article>

  <nav class="mt-12 flex justify-between border-t border-stone-800 pt-6 text-sm">
    {(() => {
      const idx = DOCS_NAV.findIndex((i) => i.slug === nav.slug);
      const prev = DOCS_NAV[idx - 1];
      const next = DOCS_NAV[idx + 1];
      return (
        <>
          <span>
            {prev && (
              <a href={withBase(`docs/${prev.slug}`)} class="text-stone-400 hover:text-orange-300">
                ← {prev.title}
              </a>
            )}
          </span>
          <span>
            {next && (
              <a href={withBase(`docs/${next.slug}`)} class="text-stone-400 hover:text-orange-300">
                {next.title} →
              </a>
            )}
          </span>
        </>
      );
    })()}
  </nav>
</DocsLayout>
